<pre class=3D"syntaxhighlighter-pre" data-syntaxhighlighter-params=3D"brush=
: py; gutter: false; theme: Confluence; collapse: true" data-theme=3D"Confl=
uence">import base64
import json

import requests
from httpsig.requests_auth import HTTPSignatureAuth
from datetime import datetime


def get_auth(key_id, key_secret):
    signature_headers =3D ['(request-target)', 'accept', 'date']
    auth =3D HTTPSignatureAuth(key_id=3Dkey_id, secret=3Dkey_secret, algori=
thm=3D'hmac-sha256',
                             headers=3Dsignature_headers)
    return auth


def get_header():
    gmt_form =3D '%a, %d %b %Y %H:%M:%S GMT'
    headers =3D {
        'Accept': 'application/json',
        'X-JMS-ORG': '00000000-0000-0000-0000-000000000002',
        'Date': datetime.utcnow().strftime(gmt_form)
    }
    return headers


class UserClient(object):

    def __init__(self, base_url, access_key, access_secret):
        self.base_url =3D base_url
        self.access_key =3D access_key
        self.access_secret =3D access_secret

    def create_token(self, **data):
        url =3D f"{self.base_url}/api/v1/authentication/super-connection-to=
ken/"
        auth =3D get_auth(self.access_key, self.access_secret)
        headers =3D get_header()
        resp =3D requests.post(url, headers=3Dheaders, auth=3Dauth, json=3D=
data)
        return resp.json()

    def get_connect_token_auth_info(self, token):
        data =3D {
            "id": token,
            "expire_now": False,
        }
        url =3D f"{self.base_url}/api/v1/authentication/super-connection-to=
ken/secret/"
        access_key =3D self.access_key
        access_secret =3D self.access_secret
        auth =3D get_auth(access_key, access_secret)
        res =3D requests.post(url, headers=3Dget_header(), auth=3Dauth, jso=
n=3Ddata)
        return res.json()


def main():
    base_url =3D 'http://localhost:8080'
    access_key =3D 'c3f42485-e437-43a4-ae3b-492840b1806e'
    access_secret =3D 'f2e0dcbd-94ee-4be7-9227-687f3f2d9312'
    user_client =3D UserClient(base_url, access_key, access_secret)
    data =3D {
        "user": "d94e9617-9b3d-4768-9afc-16c20db29b57",
        "asset": "20724755-6862-41da-8e25-38a0fc949482",
        "account": "root",
        "protocol": "rdp",
        "connect_method": "rdp",
    }
    token =3D user_client.create_token(**data)
    print("create token: ", token['id'])
    print("=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D get token=
 detail =3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D")
    detail =3D user_client.get_connect_token_auth_info(token['id'])
    print(json.dumps(detail, indent=3D2, ensure_ascii=3DFalse))
    print("=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D get token=
 base64 =3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D=3D")
    print(base64.b64encode(json.dumps(detail).encode()).decode())


if __name__ =3D=3D '__main__':
    main()
